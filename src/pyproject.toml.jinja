[#- renovate: datasource=pypi depName=singer-sdk #]
[%- set SINGER_SDK_VERSION = "0.54.2" -%]
[%- set prefix = tap_id|replace('-', '_')|upper -%]

[build-system]
build-backend = "hatchling.build"
requires = [
  "hatch-vcs",
  "hatchling",
]

[project]
name = "[[ tap_package_distribution_name ]]"
description = "Singer tap for [[ tap_source_name ]], built with the Meltano SDK for Singer Taps."
readme = "README.md"
keywords = [
  "ELT",
  "[[ tap_source_name ]]",
  "singer.io",
]
license = "Apache-2.0"
requires-python = ">=3.12"
classifiers = [
  "Programming Language :: Python :: 3 :: Only",
  "Programming Language :: Python :: 3.12",
  "Programming Language :: Python :: 3.13",
  "Programming Language :: Python :: 3.14",
]
dynamic = [
  "version",
]
dependencies = [
  [%- if tap_stream_type == 'REST' and tap_auth_method == 'Basic Auth' %]
  "requests>=2.34,<3",
  [%- endif %]
  [%- if tap_auth_method == 'JWT' %]
  "singer-sdk[jwt]~=[[ SINGER_SDK_VERSION ]]",
  [%- else %]
  "singer-sdk~=[[ SINGER_SDK_VERSION ]]",
  [%- endif %]
]
[[ "[[project.authors]]" ]]
name = "[[ author_fullname ]]"
email = "[[ author_email ]]"
[[ "[[project.maintainers]]" ]]
name = "[[ author_fullname ]]"
email = "[[ author_email ]]"
[project.scripts]
[[ tap_package_command_line_name ]] = "[[ tap_package_import_name ]].tap:Tap[[ tap_source_id ]].cli"
[project.urls]
Documentation = "https://[[ repository_provider ]]/[[ repository_namespace ]]/[[ repository_name ]]#readme"
Homepage = "https://[[ repository_provider ]]/[[ repository_namespace ]]/[[ repository_name ]]"
Repository = "https://[[ repository_provider ]]/[[ repository_namespace ]]/[[ repository_name ]]"

[dependency-groups]
dev = [
  { include-group = "testing" },
  { include-group = "typing" },
]
testing = [
  "deptry>=0.23",
  "pytest>=9",
  "singer-sdk[testing]",
]
typing = [
  "mypy>=2",
  "ty>=0.0.30",
  { include-group = "testing" },
]

[tool.hatch.version]
fallback-version = "0.0.0"
source = "vcs"

[tool.uv]
required-version = ">=0.10"

[tool.ruff]
line-length = 88
[tool.ruff.lint]
select = [
  "ALL",
]
ignore = [
  "COM812", # missing-trailing-comma
  "DJ",     # flake8-django
  "FIX002", # line-contains-todo
  "ISC001", # single-line-implicit-string-concatenation
  "PD",     # pandas-vet
]
per-file-ignores."tests/*" = [
  "ANN201", # missing-return-type-public-function
  "S101",   # assert
  "SLF001", # private-member-access
]
unfixable = [
  "ERA001", # commented-out-code
]
flake8-annotations.allow-star-arg-any = true
isort.known-first-party = [
  "[[ tap_package_import_name ]]",
]
isort.required-imports = [
  "from __future__ import annotations",
]
pydocstyle.convention = "google"

[tool.deptry.package_module_name_map]
mypy = "mypy"
ty = "ty"

[tool.pyproject-fmt]
table_format = "long"

[tool.mypy]
enable_error_code = [
  "ignore-without-code",
  "redundant-expr",
  "truthy-bool",
]
strict = true
warn_redundant_casts = true
warn_return_any = true
warn_no_return = true
warn_unreachable = true
warn_unused_configs = true
warn_unused_ignores = true

[tool.pytest]
addopts = [
  "-v",
  "--durations=10",
  "-ra",
]
filterwarnings = [
  "error",
  "once:No records were available to test:UserWarning",
]
log_level = "INFO"
minversion = "9"
strict = true
testpaths = [ "tests" ]

[tool.tox]
min_version = "4.32"
requires = [
  "tox>=4.52",
  "tox-uv",
]
env_list = [
  "dependencies",
  "typing",
  { product = [
    { prefix = "py3", start = 12, stop = 14 },
  ] },
]
[tool.tox.env.dependencies]
dependency_groups = [ "testing" ]
commands = [
  [ "deptry", { replace = "posargs", default = [ "." ], extend = true } ],
]

[tool.tox.env.typing]
dependency_groups = [ "typing" ]
commands = [
  [ "mypy", { replace = "posargs", default = [ "[[ tap_package_import_name ]]", "tests" ], extend = true } ],
  [ "ty", "check", { replace = "posargs", default = [ "[[ tap_package_import_name ]]", "tests" ], extend = true } ],
]

[tool.tox.env_run_base]
runner = "uv-venv-lock-runner"
pass_env = [
  [%- if repository_provider == "github.com" %]
  "GITHUB_*",
  [%- endif %]
  "[[ prefix ]]_*",
]
dependency_groups = [ "testing" ]
commands = [ [ "pytest", { replace = "posargs", default = [ "tests" ], extend = true } ] ]
